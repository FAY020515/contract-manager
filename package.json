{
  "name": "contract-manager",
  "version": "1.0.1",
  "description": "\u5408\u540c\u7ba1\u7406\u7cfb\u7edf",
  "author": "Contract Manager",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/contract-manager"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "dev:web": "concurrently -k \"vite\" \"node server/index.js\"",
    "build": "vite build",
    "server": "node server/index.js",
    "start": "cross-env NODE_ENV=production electron .",
    "pack": "vite build && electron-builder",
    "package": "node scripts/package-server.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "sql.js": "^1.11.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.4.0",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "antd": "^5.21.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "dayjs": "^1.11.13",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "typescript": "^5.5.4",
